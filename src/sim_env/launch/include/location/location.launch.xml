<launch>
    <!-- robot type -->
    <arg name="robot" />
    <!-- namespace -->
    <arg name="robot_namespace" />
    <arg name="start_ns" default="false" />
    <!-- robot initial pose -->
    <arg name="robot_x" />
    <arg name="robot_y" />
    <arg name="robot_z" />
    <!-- location method -->
    <arg name="method" default="amcl" />

    <node pkg="amcl" type="amcl" name="amcl" if="$(eval arg('method')=='amcl')">
        <rosparam file="$(eval find('sim_env') + '/config/robots/' + arg('robot') + '/amcl_params_' + arg('robot') + '.yaml')" command="load" />
        <param name="initial_pose_x" value="$(arg robot_x)" />
        <param name="initial_pose_y" value="$(arg robot_y)" />
        <param name="initial_pose_z" value="$(arg robot_z)" />
        <!-- multi-agent -->
        <param name="odom_frame_id" value="$(arg robot_namespace)/odom" if="$(arg start_ns)" />
        <param name="base_frame_id" value="$(arg robot_namespace)/base_footprint" if="$(arg start_ns)" />

        <remap from="static_map" to="/static_map" />
    </node>

    <node pkg="robot_localization" type="ekf_localization_node" name="ekf_localization"
        clear_params="true" output="screen" if="$(eval arg('method')=='ekf')">
        <rosparam file="$(eval find('sim_env') + '/config/robots/' + arg('robot') + '/ekf_params_' + arg('robot') + '.yaml')" command="load"/>
    </node>
    <node pkg="tf" type="static_transform_publisher" name="map_odom_broadcaster"
        args="0 0 0 0 0 0 1 map odom 100" if="$(eval arg('method')=='ekf')" />
</launch>